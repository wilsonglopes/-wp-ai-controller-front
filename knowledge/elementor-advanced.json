{
  "version": "1.0.0",
  "description": "Conhecimento avançado do Elementor — backgrounds, overlays, tipografia, animações, ícones, layouts e padrões",

  "container_advanced": {
    "background": {
      "description": "Todos os tipos de background para containers",
      "classic_color": {
        "example": {
          "background_background": "classic",
          "background_color": "#1a1a2e"
        }
      },
      "classic_image": {
        "example": {
          "background_background": "classic",
          "background_image": { "url": "https://url-da-imagem.jpg", "id": 0 },
          "background_position": "center center",
          "background_size": "cover",
          "background_repeat": "no-repeat",
          "background_attachment": "fixed"
        }
      },
      "image_with_overlay": {
        "description": "PADRÃO HERO: imagem de fundo + overlay escuro para texto legível",
        "example": {
          "background_background": "classic",
          "background_image": { "url": "https://url-foto-candidato.jpg", "id": 0 },
          "background_position": "center center",
          "background_size": "cover",
          "background_overlay_background": "classic",
          "background_overlay_color": "rgba(0,0,0,0.65)",
          "background_overlay_opacity": { "unit": "px", "size": 0.65 }
        }
      },
      "gradient_linear": {
        "example": {
          "background_background": "gradient",
          "background_gradient_type": "linear",
          "background_color": "#1a237e",
          "background_color_b": "#0d47a1",
          "background_gradient_angle": { "unit": "deg", "size": 135 }
        }
      },
      "gradient_with_overlay": {
        "description": "Gradiente diagonal — ótimo para hero sem foto",
        "example": {
          "background_background": "gradient",
          "background_gradient_type": "linear",
          "background_color": "#0d47a1",
          "background_color_b": "#1b5e20",
          "background_gradient_angle": { "unit": "deg", "size": 135 }
        }
      },
      "video_background": {
        "example": {
          "background_background": "video",
          "background_video_link": "https://www.youtube.com/watch?v=VIDEO_ID",
          "background_play_on_mobile": "yes",
          "background_video_fallback": { "url": "https://fallback-image.jpg", "id": 0 }
        }
      }
    },

    "layout_patterns": {
      "full_screen_hero": {
        "description": "Hero full screen — usado como primeira seção do site",
        "settings": {
          "content_width": "full",
          "flex_direction": "column",
          "flex_justify_content": "center",
          "flex_align_items": "center",
          "min_height": { "unit": "vh", "size": 100 },
          "padding": { "unit": "px", "top": "80", "right": "40", "bottom": "80", "left": "40", "isLinked": false }
        }
      },
      "section_boxed": {
        "description": "Seção de conteúdo centralizado com largura máxima",
        "settings": {
          "content_width": "boxed",
          "flex_direction": "column",
          "flex_align_items": "center",
          "padding": { "unit": "px", "top": "80", "right": "20", "bottom": "80", "left": "20", "isLinked": false }
        }
      },
      "two_columns": {
        "description": "Layout de duas colunas lado a lado — pai row, filhos 50%",
        "parent_settings": {
          "content_width": "boxed",
          "flex_direction": "row",
          "gap": { "unit": "px", "size": 40 },
          "flex_align_items": "center",
          "flex_wrap": "wrap",
          "padding": { "unit": "px", "top": "80", "right": "20", "bottom": "80", "left": "20", "isLinked": false }
        },
        "child_settings": {
          "width": { "unit": "%", "size": 50 },
          "flex_direction": "column"
        },
        "note": "Em mobile, os filhos automaticamente ficam 100% de largura quando flex_wrap=wrap"
      },
      "three_columns": {
        "description": "Grade de três colunas — para cards de propostas ou serviços",
        "parent_settings": {
          "content_width": "boxed",
          "flex_direction": "row",
          "flex_wrap": "wrap",
          "gap": { "unit": "px", "size": 30 },
          "padding": { "unit": "px", "top": "60", "right": "20", "bottom": "60", "left": "20", "isLinked": false }
        },
        "child_settings": {
          "width": { "unit": "%", "size": 30 },
          "flex_direction": "column",
          "flex_align_items": "center",
          "padding": { "unit": "px", "top": "30", "right": "20", "bottom": "30", "left": "20", "isLinked": false },
          "background_background": "classic",
          "background_color": "#ffffff",
          "border_radius": { "unit": "px", "top": "12", "right": "12", "bottom": "12", "left": "12", "isLinked": true },
          "box_shadow_box_shadow_type": "yes",
          "box_shadow_box_shadow": { "horizontal": 0, "vertical": 4, "blur": 20, "spread": 0, "color": "rgba(0,0,0,0.08)" }
        }
      },
      "sticky_header": {
        "description": "Container fixo no topo da página",
        "settings": {
          "content_width": "full",
          "flex_direction": "row",
          "flex_justify_content": "space-between",
          "flex_align_items": "center",
          "padding": { "unit": "px", "top": "15", "right": "40", "bottom": "15", "left": "40", "isLinked": false },
          "background_background": "classic",
          "background_color": "#ffffff",
          "position": "sticky",
          "sticky": "top",
          "z_index": 100,
          "box_shadow_box_shadow_type": "yes",
          "box_shadow_box_shadow": { "horizontal": 0, "vertical": 2, "blur": 10, "spread": 0, "color": "rgba(0,0,0,0.1)" }
        }
      }
    },

    "borders_and_shadows": {
      "card_shadow": {
        "box_shadow_box_shadow_type": "yes",
        "box_shadow_box_shadow": { "horizontal": 0, "vertical": 4, "blur": 20, "spread": 0, "color": "rgba(0,0,0,0.1)" }
      },
      "strong_shadow": {
        "box_shadow_box_shadow_type": "yes",
        "box_shadow_box_shadow": { "horizontal": 0, "vertical": 10, "blur": 40, "spread": 0, "color": "rgba(0,0,0,0.2)" }
      },
      "rounded_card": {
        "border_radius": { "unit": "px", "top": "12", "right": "12", "bottom": "12", "left": "12", "isLinked": true }
      },
      "pill": {
        "border_radius": { "unit": "px", "top": "50", "right": "50", "bottom": "50", "left": "50", "isLinked": true }
      },
      "border_bottom_accent": {
        "border_border": "solid",
        "border_width": { "unit": "px", "top": "0", "right": "0", "bottom": "4", "left": "0", "isLinked": false },
        "border_color": "#e74c3c"
      }
    }
  },

  "typography_guide": {
    "description": "Guia completo de tipografia para widgets Elementor",
    "font_families": {
      "political": ["Montserrat", "Raleway", "Oswald", "Bebas Neue"],
      "institutional": ["Open Sans", "Lato", "Source Sans Pro"],
      "elegant": ["Playfair Display", "Merriweather", "Georgia"],
      "modern": ["Inter", "Poppins", "Nunito"]
    },
    "hero_heading": {
      "description": "Título principal do hero — grande e impactante",
      "settings": {
        "typography_font_family": "Montserrat",
        "typography_font_size": { "unit": "px", "size": 72 },
        "typography_font_weight": "800",
        "typography_line_height": { "unit": "em", "size": 1.1 },
        "typography_letter_spacing": { "unit": "px", "size": 1 },
        "typography_text_transform": "none"
      }
    },
    "section_heading": {
      "description": "Título de seção — h2",
      "settings": {
        "typography_font_family": "Montserrat",
        "typography_font_size": { "unit": "px", "size": 42 },
        "typography_font_weight": "700",
        "typography_line_height": { "unit": "em", "size": 1.2 }
      }
    },
    "card_title": {
      "description": "Título de card — h3",
      "settings": {
        "typography_font_family": "Montserrat",
        "typography_font_size": { "unit": "px", "size": 22 },
        "typography_font_weight": "600"
      }
    },
    "body_text": {
      "description": "Texto corrido",
      "settings": {
        "typography_font_size": { "unit": "px", "size": 17 },
        "typography_line_height": { "unit": "em", "size": 1.7 },
        "typography_font_weight": "400"
      }
    },
    "badge_label": {
      "description": "Label/badge pequeno acima de títulos",
      "settings": {
        "typography_font_size": { "unit": "px", "size": 13 },
        "typography_font_weight": "700",
        "typography_letter_spacing": { "unit": "px", "size": 3 },
        "typography_text_transform": "uppercase"
      }
    }
  },

  "animations": {
    "description": "Animações de entrada (entrance animations) disponíveis no Elementor",
    "how_to_use": "Adicione 'animation' e opcionalmente 'animation_duration' e 'animation_delay' nas settings de qualquer widget",
    "available": {
      "fade": ["fadeIn", "fadeInDown", "fadeInUp", "fadeInLeft", "fadeInRight"],
      "zoom": ["zoomIn", "zoomInDown", "zoomInUp"],
      "slide": ["slideInDown", "slideInUp", "slideInLeft", "slideInRight"],
      "bounce": ["bounceIn", "bounceInDown", "bounceInUp"],
      "special": ["flipInX", "flipInY", "rotateIn", "lightSpeedIn"]
    },
    "durations": ["slow", "normal", "fast"],
    "examples": {
      "hero_title": {
        "animation": "fadeInDown",
        "animation_duration": "slow",
        "animation_delay": 0
      },
      "hero_subtitle": {
        "animation": "fadeInUp",
        "animation_duration": "normal",
        "animation_delay": 300
      },
      "card": {
        "animation": "fadeInUp",
        "animation_duration": "normal",
        "animation_delay": 150
      }
    }
  },

