  "responsive_guide": {
    "description": "Como tornar elementos responsivos no Elementor",
    "breakpoints": {
      "desktop": "acima de 1024px — sem sufixo nas propriedades",
      "tablet": "768px a 1024px — sufixo _tablet",
      "mobile": "abaixo de 767px — sufixo _mobile"
    },
    "examples": {
      "font_size_responsive": {
        "desktop": { "typography_font_size": { "unit": "px", "size": 72 } },
        "tablet": { "typography_font_size_tablet": { "unit": "px", "size": 48 } },
        "mobile": { "typography_font_size_mobile": { "unit": "px", "size": 36 } }
      },
      "padding_responsive": {
        "desktop": { "padding": { "unit": "px", "top": "80", "right": "40", "bottom": "80", "left": "40", "isLinked": false } },
        "mobile": { "padding_mobile": { "unit": "px", "top": "50", "right": "20", "bottom": "50", "left": "20", "isLinked": false } }
      },
      "hide_on_mobile": {
        "hide_mobile": "yes"
      },
      "flex_column_on_mobile": {
        "note": "Use flex_wrap: wrap no pai + width 50% nos filhos. No mobile ficam 100% automaticamente"
      }
    }
